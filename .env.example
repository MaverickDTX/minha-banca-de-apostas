# Modelo de variáveis de ambiente. Copie para .env e preencha com os valores do seu projeto Supabase.
# No deploy (Vercel), configure estas mesmas chaves em Project Settings > Environment Variables.

VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-publishable-(anon)-key"
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# API-Sports (fallback para autocomplete de eventos quando TheSportsDB não retorna resultados)
# Free tier: 100 requests/dia. Obtenha em https://api-sports.io/
VITE_API_SPORTS_KEY=""
